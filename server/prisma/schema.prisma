// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid())
  username String @db.VarChar(50) @unique
  password String
  email String @unique
  role Role @default(USER)
  profile Profile?
  ascents Ascent[]
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("users")
}

model Profile{
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id])
  userId String @unique
  sex Sex?
  age Int?
  climbingStart DateTime?
  personalBest String? @db.VarChar(5)
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("profiles")
}

model Route{
  id String @id @default(uuid())
  name String
  crag Crag @relation(fields: [cragName, areaName, country], references: [name, areaName, country])
  cragName String
  areaName String
  country String
  grade Grade @relation(fields: [gradeId], references: [id])
  gradeId String
  defaultFormat Format @relation(fields: [defaultFormatId], references: [id])
  defaultFormatId String
  length Int?
  year DateTime?
  firstAscent String?
  boltNumber Int?
  additionalInfo String?
  ascents Ascent[]
  routeHistory RouteHistory[]
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("routes")
}

model RouteHistory{
  id String @id @default(uuid())
  route Route @relation(fields: [routeId], references: [id])
  routeId String
  changesJson Json
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("route_history")
}

model Ascent{
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id])
  userId String
  route Route @relation(fields: [routeId], references: [id])
  routeId String
  ascentDate DateTime @default(now())
  style Style @relation(fields: [styleId], references: [id])
  styleId String
  format Format @relation(fields: [formatId], references: [id])
  formatId String
  myGrade Grade @relation(fields: [myGradeId], references: [id])
  myGradeId String
  personalOpinion String?
  stars Int
  visibility Visibility @default(PUBLIC)
  ascentHistory AscentHistory[]
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("ascents")
}

model AscentHistory{
  id String @id @default(uuid())
  ascent Ascent @relation(fields: [ascentId], references: [id])
  ascentId String
  changesJson Json
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("ascent_history")
}

model Format{
  id String @id @default(uuid())
  format String @unique
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt
  ascent Ascent[]
  route Route[]

  @@map("formats")
}

model Grade{
  id String @id @default(uuid())
  grade String @unique
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt
  ascent Ascent[]
  route Route[]

  @@map("grades")
}

model Style{
  id String @id @default(uuid())
  style String @unique
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt
  ascent Ascent[]

  @@map("styles")
}

model Crag{
  name String
  area Area @relation(fields: [areaName, country], references: [name, country])
  areaName String
  country String
  routes Route[]
  material Material @relation(fields: [materialId], references: [id])
  materialId String
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@id([name, areaName, country])
  @@map("crags")
}

model Area{
  name String
  country String
  crags Crag[]
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@id([name, country])
  @@map("areas")
}

model Material{
  id String @id @default(uuid())
  material String @unique
  crag Crag[]
  CreatedOn DateTime @default(now())
  UpdatedOn DateTime @updatedAt

  @@map("materials")
}

enum Sex {
  MALE
  FEMALE
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}
